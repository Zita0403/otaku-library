<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"/>
    <link rel="stylesheet" type='text/css' href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
    <!-- Own Stylsheet-->
    <link rel="stylesheet" href="/styles/style.css">
    <!-- Font style -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&display=swap" rel="stylesheet">
    <!-- Navigation font style -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="canonical" href="https://otakulibrary.zita.dev/">
    <title><%= (locals.title) ? title + ' | Otaku Library' : 'Otaku Library' %></title>
    <!-- Meta tags -->
    <meta name="description" content="<%= (locals.description) ? description : 'Welcome to Otaku Library - Your favorite anime database.' %>">
    <% 
      let finalImage = (typeof ogImage !== 'undefined' && ogImage) 
          ? (ogImage.startsWith('http') ? ogImage : 'https://otakulibrary.zita.dev' + ogImage) 
          : 'https://otakulibrary.zita.dev/images/og-image.jpg'; 
    %>
    <!-- Open Graph meta tags -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://otakulibrary.zita.dev<%= typeof url !== 'undefined' ? url : '' %>">
    <meta property="og:title" content="<%= title ? title : 'Otaku Library' %>">
    <meta name="description" content="<%= (locals.description) ? description : 'Welcome to Otaku Library - Your favorite anime database.' %>">
    <meta property="og:image" content="<%= (typeof ogImage !== 'undefined' && ogImage) ? (ogImage.startsWith('http') ? ogImage : 'https://otakulibrary.zita.dev' + ogImage) : 'https://otakulibrary.zita.dev/images/og-image.jpg' %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <!-- Twitter Card meta tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="https://otakulibrary.zita.dev<%= typeof url !== 'undefined' ? url : '' %>">
    <meta name="twitter:title" content="<%= title ? title : 'Otaku Library' %>">
    <meta name="twitter:description" content="<%= description %>">
    <meta name="twitter:image" content="<%= finalImage %>">
</head>
<body>
    <canvas id="sakura-canvas"></canvas>
    <header> 
        <div class="header-left">
            <a href="/"> 
                <img src="/images/otaku.png" style="width: 60px; height: 60px;" class="me-2">
                <h1>Otaku Library</h1> 
            </a> 
            <ul class="nav"> 
                <li class="nav-item"><a href="/">Home</a></li>
                <li class="nav-item"><a href="#">Genres</a>
                    <ul class="sub-nav">
                        <% genres.forEach(genre => { %>
                        <li>
                            <a href="/genre/<%= genre.mal_id %>/<%= genre.name %>"><%= genre.name %></a>
                        </li>
                        <% }); %>
                    </ul>
                </li>
                <li class="nav-item"><a href="/top">Toplist</a></li>
            </ul> 
        </div>

        <div class="header-row">
            <div class="header-center">
                <form role="search" action="/search" method="GET"> 
                    <input class="search" type="search" name="q" placeholder="Search..."> 
                    <div id="autocomplete-list"></div>
                </form>
            </div>

        <% if (!locals.user) { %>
            <a href="#" class="mobile-nav-toggle">
                <i class="fa-solid fa-arrow-right-to-bracket"></i>  
            </a>
        <% } %>

            <div class="header-right">
                <a href="https://github.com/Zita0403/otaku-library">
                    <i class="fa-brands fa-github github-icon"></i>
                </a>
                <div id="account-login">
                <% if (locals.user) { %>
                <div class="user-dropdown">
                    <div class="dropdown-trigger">
                        <span><%= user.user_name %></span>
                        <i class="fa-solid fa-chevron-down"></i>
                    </div>
                    <ul class="dropdown-menu">
                        <li class="dropdown-header">
                            <strong><%= user.user_name %></strong><br>
                            <small><%= user.email %></small>
                        </li>
                        <hr>
                        <li><a href="/auth/account#settings"><i class="fa-solid fa-user"></i> Profile</a></li>
                        <li><a href="/auth/account"><i class="fa-solid fa-gear"></i> Settings</a></li>
                        <hr>
                        <li><a href="/auth/logout" class="logout-btn"><i class="fa-solid fa-right-from-bracket"></i> Log out</a></li>
                    </ul>
                </div>
                    <% } else { %>
                        <div class="auth-group">
                            <a href="/auth/login" id="login">
                                <p>Sign in</p>
                            </a>
                            <span>/</span>
                            <a href="/auth/register" id="register">
                                <p>Sign up</p>
                            </a>
                        </div>
                    <% } %>
                </div>
            </div> 
        </div>

    </header>
    <nav class="mobile-nav">
        <a href="/" class="nav-item">
            <i class="fa-solid fa-house"></i>
        </a>
        <a href="/top" class="nav-item">
            <i class="fa-solid fa-thumbs-up"></i>
        </a>
        <div href="#" class="nav-item sub-mobile-nav-toggle"><i class="fa-solid fa-masks-theater"></i>
            <ul class="sub-mobile-nav">
                <% genres.forEach(genre => { %>
                <li>
                    <a href="/genre/<%= genre.mal_id %>/<%= genre.name %>"><%= genre.name %></a>
                </li>
                <% }); %>
            </ul>
        </div>
        <label for="search-input-id" class="nav-item search-button">
            <i class="fa-solid fa-magnifying-glass"></i>
        </label>
    </nav>
    <main class="main-sect">